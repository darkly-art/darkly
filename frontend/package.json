{
    "name": "darkly-frontend",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "wasm:build-dev": "cd wasm && wasm-pack build --dev --target web --out-dir pkg",
        "wasm:build-dev-profile": "cd wasm && wasm-pack build --dev --target web --out-dir pkg -- --features profile",
        "wasm:build": "cd wasm && wasm-pack build --release --target web --out-dir pkg",
        "dev": "vite",
        "start": "npm run wasm:build-dev && vite",
        "start:profile": "npm run wasm:build-dev-profile && vite",
        "build": "npm run wasm:build && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@vitejs/plugin-basic-ssl": "^2.1.4",
        "@webgpu/types": "^0.1.69",
        "svelte": "^5.0.0",
        "typescript": "^5.7.0",
        "vite": "^6.0.0",
        "vitest": "^2.1.0"
    },
    "dependencies": {
        "defu": "^6.1.4",
        "fflate": "^0.8.2",
        "tinykeys": "^3.0.0"
    }
}
